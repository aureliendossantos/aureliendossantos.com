---
interface Props {
	wide: boolean
	full: boolean
}
const { wide, full } = Astro.props
---

<div class:list={["gallery not-prose", { wide: wide, full: full }]}>
	<slot />
</div>

<style is:global>
	@reference "#tailwind.css";

	.gallery {
		@apply relative my-6 flex flex-row justify-center;
		figure {
			@apply my-0 grow basis-4;
		}
		figure + figure {
			@apply ml-[10px];
		}
		&.wide {
			@apply mediumlarge:mx-[-40px] medium:mx-[-20px] mx-[-80px];
		}
		img {
			@apply w-full;
		}
		.article-styling:not(.with-sidenotes) &.full {
			@apply left-1/2 ml-[-50vw] w-screen;
			figcaption {
				@apply mr-[.5em] ml-auto;
			}
		}
		.article-styling.with-sidenotes &.full {
			@apply my-(--indent) w-[calc(150%+4em)] xl:mb-(--indent) xl:w-full;
			figcaption {
				@apply mr-[.5em] ml-auto;
			}
		}
	}
</style>
